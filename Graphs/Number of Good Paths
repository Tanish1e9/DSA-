// Ye bhut khatarnaak question tha, took me a lot of time to get to the solution
// Dekh isme main intuition aise soche ki suppose har value k according nodes ko segregate kr lie
// ab largest value waale to saare nodes hi aapas me connected honge
// fir second largest waalo ko bas largest wala rok skta h
// to ek tarah se largest waale nodes ko gayab kr denge
// ab gayab to aise kr nhi skte to ulta soche ki smallest value to largest value node jayenge
// aur graph banate jayenge DSU se, aur fir ek component me jitne bhi current value ke nodes honge
// unka nC2 jod lenge
// Wo bhi kaise krenge ki pehle sabko merge krke bana do component
// then fir se iterate kro, har ek bar component touch krne par increment by 1 (as if you are aliving the nodes one by one)
// Aur bas aise ho jayega (ye wala part bhi thoda tricky laga tha)
// Firse iterate islie krna hoga ki components badalte rhenge na, to sabko merge krne pe stable ho jaye

class DSU{
    public:
    vector<int> parent, size;
    DSU(int n) {
        size.assign(n, 1);
        parent.resize(n);
        iota(parent.begin(), parent.end(), 0);
    }
    int find_par(int node) {
        if(parent[node]==node) return node;
        return parent[node] = find_par(parent[node]);
    }
    void union_by_size(int a, int b) {
        int ult_a = find_par(a);
        int ult_b = find_par(b);
        if(ult_a == ult_b) return;
        if(size[ult_a] > size[ult_b]) {
            size[ult_a] += size[ult_b];
            parent[ult_b] = ult_a;
        }
        else {
            size[ult_b] += size[ult_a];
            parent[ult_a] = ult_b;
        }
    }
};
class Solution {
public:
    void merge(int node, auto &adj, auto &ds) {
        for(int el:adj[node]) {
            ds.union_by_size(el, node);
        }
    }
    int numberOfGoodPaths(vector<int>& vals, vector<vector<int>>& edges) {
        int n = edges.size()+1;
        vector<vector<int>> adj(n);
        for(auto &e:edges) {
            // Ek edge tabhi active hoga jab dono ends active ho 
            // To bade value node ko hi iss edge ka responsibility de do (kyunki wo baad me active hoga)
            if(vals[e[0]] > vals[e[1]]) adj[e[0]].push_back(e[1]);
            else adj[e[1]].push_back(e[0]);
        }

        DSU ds(n);
        vector<int> nodes(n);
        iota(nodes.begin(), nodes.end(), 0);
        sort(nodes.begin(), nodes.end(), [&vals](int a, int b){
            return vals[a] < vals[b];
        });

        int ans = n;
        vector<pair<int,int>> last_vis(n, {-1,-1});
        
        for(int i=0;i<n;i++) {
            int j = i;
            merge(nodes[i], adj, ds);
            while(i+1<n && vals[nodes[i+1]] == vals[nodes[i]]) {
                i++;
                merge(nodes[i], adj, ds);
            }
            for(int p=j;p<=i;p++) {
                auto &curr = last_vis[ds.find_par(nodes[p])];
                // Here i is just an indicator ki kaha tk le lia
                // iske bajay vals[nodes[i]] bhi use kr skte the
                // point yahi h ki identify ho ske ki current turn me 
                // already touch kia ja chuka h ye ya nahi
                if(curr.second < i) {
                    curr.second = i;
                    curr.first = 1;
                }
                else {
                    ans += curr.first;
                    curr.first++;
                }
            }
        }
        return ans;
    }
};

