// Ye waisa hi question h Holes jaisa
// interblock links maintain krenge jisse atmost rootN*10 updates ho and atmost rootN steps for query
// Infinity can only occur as ><

#include<bits/stdc++.h>
using namespace std;
#define int long long

signed main() {
    ios::sync_with_stdio(false);
    cin.tie(nullptr);

    int n,m,q;
    cin >> n >> m >> q;
    vector<vector<char>> arr(n+2, vector<char>(m+2));
    for(int i=1;i<=n;i++) {
        for(int j=1;j<=m;j++) {
            cin >> arr[i][j];
        }
    }
    vector<vector<pair<int,int>>> next(n+2, vector<pair<int,int>>(m+2));
    for(int j=1;j<=m;j++) {
        next[0][j] = {0,j};
        next[n+1][j] = {n+1,j};
    }
    for(int i=1;i<=n;i++) {
        next[i][0] = {i,0};
        next[i][m+1] = {i,m+1};
    }
    const int B = ceil(sqrt(n+2));
    for(int i=1;i<=n;i++) {
        queue<pair<int,int>> q;
        // Jis jis position ke lie we know the answer
        // usko queue me daal denge
        // observe infinity ke lie dono taraf check kr rhe islie i,j ke saath i,j-1/j+1 ni dalne ka jroorat
        // wo apne aap aa jayega
        for(int j=1;j<=m;j++) {
            if(arr[i][j-1]=='>' && arr[i][j]=='<') {
                next[i][j] = {-1,-1};
                q.push({i,j});
            }
            else if(arr[i][j]=='>' && arr[i][j+1]=='<') {
                next[i][j] = {-1,-1};
                q.push({i,j});
            }
            else if(arr[i][j]=='<' && j==1) {
                next[i][j] = {i,j-1};
                q.push({i,j});
            }
            else if(arr[i][j]=='>' && j==m) {
                next[i][j] = {i,j+1};
                q.push({i,j});
            }
            else if(arr[i][j]=='^') {
                if((i-1)/B != i/B) next[i][j] = {i-1,j};
                else next[i][j] = next[i-1][j];
                
                q.push({i,j});
            }
        }
        while(!q.empty()) {
            auto [i,j] = q.front();
            q.pop();

            // Ensure ki infinite loop me na ghus jaye
            if(j+1 <= m && arr[i][j+1]=='<' && arr[i][j]!='>') {
                next[i][j+1] = next[i][j];
                q.push({i,j+1});
            }
            if(j-1 >= 0 && arr[i][j-1]=='>' && arr[i][j]!='<') {
                next[i][j-1] = next[i][j];
                q.push({i,j-1});
            }
        }
    }


    while(q--) {
        char type;
        cin >> type;
        int x,y;
        cin >> x >> y;
        int b = x/B;
        if(type == 'C') {
            char z;
            cin >> z;
            arr[x][y] = z;

            queue<pair<int,int>> q;
            q.push({x,y});
            // Yaha par agar infinity create ho jaye to dono daalna hoga bcz sirf x,y pe check kr rhe
            if(z == '^') {
                if((x-1)/B == b) next[x][y] = next[x-1][y];
                else next[x][y] = {x-1,y};
            }
            else if(z == '<') {
                if(arr[x][y-1]=='>') {
                    next[x][y] = {-1,-1};
                    next[x][y-1] = {-1,-1};
                    q.push({x,y-1});
                }
                else next[x][y] = next[x][y-1];
            }
            else {
                if(arr[x][y+1]=='<') {
                    next[x][y] = {-1,-1};
                    next[x][y+1] = {-1,-1};
                    q.push({x,y+1});
                }
                else next[x][y] = next[x][y+1];
            }
            
            
            while(!q.empty()) {
                auto [i,j] = q.front();
                q.pop();

                // Upar wala hi BFS logic h bas updates k lie ye downward taraf bhi jana hoga
                if((i+1)/B == b && i+1 <= n && arr[i+1][j]=='^') {
                    next[i+1][j] =  next[i][j];
                    q.push({i+1,j});
                }
                if(j+1 <= m && arr[i][j+1]=='<' && arr[i][j]!='>') {
                    next[i][j+1] = next[i][j];
                    q.push({i,j+1});
                }
                if(j-1 >= 0 && arr[i][j-1]=='>' && arr[i][j]!='<') {
                    next[i][j-1] = next[i][j];
                    q.push({i,j-1});
                }
            }
        }
        else {
            int currx = x, curry = y;
            while(currx!=-1 && curry!=-1 && currx > 0 && curry > 0 && curry < m+1) {
                auto val = next[currx][curry];
                currx = val.first, curry = val.second;
            }
            cout << currx << " " << curry << "\n";
        }
    }
    return 0;
}
