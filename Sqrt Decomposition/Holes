// Ye wala dekh simple form 1 - block acceleration wala h
// Our aim is to keep going from i -> next -> next ...
// Bas we won't jump in the same block that will be accelerated 
// To root n me answer pata lag jayega
// and even updates me root n nodes ko hi atmax update krna hoga

#include<bits/stdc++.h>
using namespace std;
#define int long long

void update(auto &dp, auto &next_block, auto &arr, int s, int e) {
    int n = arr.size();
    const int B = sqrt(n);
    for(int i=e;i>=s;i--) {
        if(i+arr[i] >= n) {
            dp[i] = 1;
            next_block[i] = -1;
        }
        else if((i+arr[i])/B > i/B) {
            dp[i] = 1;
            next_block[i] = i+arr[i];
        }
        else {
            dp[i] = 1+dp[i+arr[i]];
            next_block[i] = next_block[i+arr[i]];
        }
    }
}
signed main() {
    ios::sync_with_stdio(false);
    cin.tie(0);
 
    int n, m;
    cin >> n >> m;
    vector<int> arr(n);
    for(int i=0;i<n;i++) cin >> arr[i];

    const int B = sqrt(n);
    vector<int> dp(n);
    vector<int> next_block(n,-1);
    update(dp,next_block,arr,0,n-1);

    for(int i=0;i<m;i++) { 
        int type;
        cin >> type;
        if(type == 0) {
            int a, b;
            cin >> a >> b;a--;
            arr[a] = b;
            
            int block_start = (a/B)*B;
            update(dp, next_block, arr, block_start, a);
        }
        else {
            int start;
            cin >> start;
            start--;
            int jumps = 0;
            while(next_block[start]!=-1) {
                jumps += dp[start];
                start = next_block[start];
            }

            while(start + arr[start] < n) {
                jumps++;
                start += arr[start];
            }

            // 1-based indexing and counting the last jump
            cout << start+1 << " " << jumps+1 << "\n";
        }
    }
    
    return 0;
}
