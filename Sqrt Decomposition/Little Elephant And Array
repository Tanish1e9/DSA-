// M-1 O(nlogn) hai ye wala
// Ekdum Distinct Values Queries (CSES) ki tarah ka h
// right ke hisab se sort kro and ek bar me saari queries ending at a given R ko answer krenge
// To right se kisi element x ke xth position ko 1 rakhenge aur uske pehle waale ko -1
// To update krte waqt sochna 3 updates krna hoga
// Bas baaki to sum kr dena h segment tree se


#include<bits/stdc++.h>
using namespace std;
#define int long long

class seg_tree{
    #define L (ind<<1)+1
    #define R (ind<<1)+2
    public:
    vector<int> seg;
    seg_tree(int n) {
        seg.assign(4*n, 0);
    }
    void point_update(int ind, int low, int high, int k, int val) {
        if(k<low || high<k) return;
        if(low == high && low == k) {
            seg[ind] = val;
            return;
        }
        int mid = low + (high-low)/2;
        point_update(L, low, mid, k, val);
        point_update(R, mid+1, high, k, val);
        seg[ind] = seg[L] + seg[R];
    }
    int query(int ind, int low, int high, int l, int r) {
        if(r<low || high<l) return 0;
        if(l<=low && high<=r) return seg[ind];
        int mid = low + (high-low)/2;
        int left = query(L, low, mid, l, r);
        int right = query(R, mid+1, high, l, r);
        return left + right;
    }
    #undef L
    #undef R
};
signed main() {
    ios::sync_with_stdio(false);
    cin.tie(0);
 
    int n, m;
    cin >> n >> m;
    vector<int> arr(n);
    for(int i=0;i<n;i++) cin >> arr[i];

    vector<vector<int>> queries(m, vector<int>(3));
    for(int i=0;i<m;i++) { 
        auto &q = queries[i];
        cin >> q[0] >> q[1];
        q[0]--;
        q[1]--;
        q[2] = i;
    }

    sort(queries.begin(), queries.end(), [](auto &a, auto &b){
        return a[1] < b[1];
    });

    seg_tree stree(n);
    int r = -1;
    vector<int> ans(m);
    map<int,vector<int>> pos;
    for(auto &q:queries) {
        while(r < q[1]) {
            r++;
            auto &vec = pos[arr[r]];
            vec.push_back(r);
            if(vec.size() >= arr[r]) stree.point_update(0,0,n-1,vec[vec.size()-arr[r]],1);
            if(vec.size() >= arr[r]+1) stree.point_update(0,0,n-1,vec[vec.size()-arr[r]-1],-1);
            if(vec.size() >= arr[r]+2) stree.point_update(0,0,n-1,vec[vec.size()-arr[r]-2],0);
        }
        ans[q[2]] = stree.query(0,0,n-1,q[0],q[1]);
    }

    for(int i:ans) {
        cout << i << "\n";
    }
    
    return 0;
}




// M-2 O((n+q)rootn) Mo's Algorithm 
// Badhia algo h simple sa bhi h bhut jagah pe sirf yahi kaam krega
// Dekh root n size ke blocks me maan lo array ko 
// Aur Mo's order me sort krna (niche comparator dekh lo... ek Hilbert order bhi hota h kabhi padhna)
// Ab isme socho to r hai wo atmost N move krega per block to O(N rootn) since root n is number of blocks
// aur jo l h wo root n move krega within a block to O(Q rootn)
// Isme bas ek chiz socho na jo elements n se bade h wo kabhi solution ho skte kya
// To unko hata ke to vector hi bana do n tk ka rather than a frequency map (Bhut fast ho jayega)

#include<bits/stdc++.h>
using namespace std;
#define int long long

void add(int x, auto &freq, int &ans) {
    if(x > freq.size()) return;
    freq[x]++;
    if(freq[x]==x) ans++;
    else if(freq[x]==x+1) ans--;
}
void remove(int x, auto &freq, int &ans) {
    if(x > freq.size()) return;

    if(freq[x]==x) ans--;
    else if(freq[x]==x+1) ans++;
    freq[x]--;
}
signed main() {
    ios::sync_with_stdio(false);
    cin.tie(0);
 
    int n, m;
    cin >> n >> m;
    vector<int> arr(n);
    for(int i=0;i<n;i++) cin >> arr[i];

    vector<vector<int>> queries(m, vector<int>(3));
    for(int i=0;i<m;i++) { 
        auto &q = queries[i];
        cin >> q[0] >> q[1];
        q[0]--;
        q[1]--;
        q[2] = i;
    }

    const int B = sqrt(n);
    sort(queries.begin(), queries.end(), [B](auto &a, auto &b){
        int ba = a[0]/B, bb = b[0]/B;
        if(ba != bb) return ba < bb;
        return (ba & 1) ? (a[1] > b[1]) : a[1] < b[1];
    });

    int l = 0, r = -1, answer = 0;
    vector<int> freq(n+1);
    vector<int> ans(m);
    for(auto &q:queries) {
        int L = q[0], R = q[1];
        while(l > L) {l--;add(arr[l],freq,answer);}
        while(r < R) {r++;add(arr[r],freq,answer);}
        while(l < L) {remove(arr[l],freq,answer);l++;}
        while(r > R) {remove(arr[r],freq,answer);r--;}

        ans[q[2]] = answer;
    }

    for(int i:ans) {
        cout << i << "\n";
    }
    
    return 0;
}



// M-2 Mo's Algorithm
// Euler Tour + Mo's ka intuition to turant aaya
// Bas ek key point ye h ki niche k buckets re remove mat kro contribution

#include<bits/stdc++.h>
using namespace std;

void add(int el, auto &freq, auto &buck) {
    freq[el]++;
    // Dont remove el's contribution from lower buckets
    buck[freq[el]]++;
}
void remove(int el, auto &freq, auto &buck) {
    // Now since freq[el] is decreased then el's contri to old freq bucket should be removed
    buck[freq[el]]--;
    freq[el]--;
}
void dfs(int node, int par, auto &adj, auto &cols, auto &tour, auto &time_start, auto &time_end) {
    time_start[node] = tour.size();
    tour.push_back(cols[node]);
    for(int el:adj[node]) {
        if(el == par) continue;
        dfs(el, node, adj, cols, tour, time_start, time_end);
    }
    time_end[node] = tour.size()-1;
}
signed main() {
    ios::sync_with_stdio(false);
    cin.tie(0);
 
    int n, m;
    cin >> n >> m;
    vector<int> cols(n+1);
    for(int i=1;i<=n;i++) cin >> cols[i];
    vector<vector<int>> adj(n+1);

    for(int i=0;i<n-1;i++) {
        int a, b;
        cin >> a >> b;
        adj[a].push_back(b);
        adj[b].push_back(a);
    }
    vector<int> tour, time_start(n+1), time_end(n+1);
    dfs(1,-1,adj,cols,tour,time_start,time_end);

    vector<vector<int>> queries(m, vector<int>(4));
    for(int i=0;i<m;i++) {
        int v, k;
        cin >> v >> k;
        queries[i][0] = time_start[v];
        queries[i][1] = time_end[v];
        queries[i][2] = k;
        queries[i][3] = i;
    }
    
    const int B = ceil(sqrt(n));
    sort(queries.begin(), queries.end(), [B](auto &a, auto &b){
        int b1 = a[0]/B, b2 = b[0]/B;
        if(b1 != b2) return b1 < b2;
        return (b1 & 1)?a[1]>b[1]:a[1]<b[1];
    });
    
    vector<int> ans(m, 0);
    vector<int> freq(100001,0);
    vector<int> freq_bucket(n+1, 0);
    int l=0, r=-1;
    for(auto &q:queries) {
        int L = q[0], R = q[1];
        while(l > L) {
            l--;
            add(tour[l], freq, freq_bucket);
        }
        while(r < R) {
            r++;
            add(tour[r], freq, freq_bucket);
        }
        while(l < L) {
            remove(tour[l], freq, freq_bucket);
            l++;
        }
        while(r > R) {
            remove(tour[r], freq, freq_bucket);
            r--;
        }
        // Important maybe that q[2] > n, there ans should be 0
        if(q[2] <= n) ans[q[3]] = freq_bucket[q[2]];
    }
    
    for(int i:ans) {
        cout << i << "\n";
    }

    return 0;
}

